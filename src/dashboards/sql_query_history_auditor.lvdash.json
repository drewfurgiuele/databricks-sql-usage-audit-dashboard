{
  "datasets": [
    {
      "name": "ds_history",
      "displayName": "Query History",
      "queryLines": [
        "SELECT statement_id, executed_by, COALESCE(execution_status, 'UNKNOWN') AS execution_status, COALESCE(compute.warehouse_id, 'serverless') AS warehouse_id, COALESCE(statement_type, 'UNKNOWN') AS statement_type, COALESCE(client_application, 'Unknown') AS client_application, total_duration_ms, ROUND(total_duration_ms / 1000.0, 2) AS total_duration_sec, CASE WHEN execution_status = 'FAILED' THEN 1 ELSE 0 END AS is_failed, CASE WHEN COALESCE(from_result_cache, false) = true THEN 1 ELSE 0 END AS cache_hit, start_time, end_time, COALESCE(read_rows, 0) AS read_rows, COALESCE(produced_rows, 0) AS produced_rows, ROUND(COALESCE(read_bytes, 0) / 1048576.0, 2) AS read_mb, COALESCE(CAST(from_result_cache AS STRING), 'false') AS from_result_cache, LEFT(COALESCE(statement_text, ''), 300) AS statement_preview, COALESCE(error_message, '') AS error_message FROM system.query.history"
      ]
    },
    {
      "name": "ds_longest_queries",
      "displayName": "Longest Running Queries",
      "queryLines": [
        "SELECT executed_by, COALESCE(execution_status, 'UNKNOWN') AS execution_status, COALESCE(compute.warehouse_id, 'serverless') AS warehouse_id, COALESCE(statement_type, 'UNKNOWN') AS statement_type, COALESCE(client_application, 'Unknown') AS client_application, total_duration_ms, ROUND(total_duration_ms / 1000.0, 2) AS total_duration_sec, ROUND(COALESCE(execution_duration_ms, 0) / 1000.0, 2) AS execution_duration_sec, ROUND(COALESCE(compilation_duration_ms, 0) / 1000.0, 2) AS compilation_duration_sec, ROUND(COALESCE(waiting_for_compute_duration_ms, 0) / 1000.0, 2) AS waiting_for_compute_sec, start_time, COALESCE(read_rows, 0) AS read_rows, COALESCE(produced_rows, 0) AS produced_rows, ROUND(COALESCE(read_bytes, 0) / 1048576.0, 2) AS read_mb, COALESCE(CAST(from_result_cache AS STRING), 'false') AS from_result_cache, LEFT(COALESCE(statement_text, ''), 500) AS statement_preview, COALESCE(error_message, '') AS error_message FROM system.query.history ORDER BY total_duration_ms DESC"
      ]
    }
  ],
